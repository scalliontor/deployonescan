# ---- Splat provider ----
# Set to "mock" (default) for the demo. The mock provider drives a fake
# processing animation and always returns the bundled sample scene.
# Set to "luma" to wire in Luma AI's 3D capture API (enterprise contact required).
SPLAT_PROVIDER=mock

# When SPLAT_PROVIDER=luma — fill these in once you have enterprise access.
# Luma's 3D Video-to-3D API is not publicly documented; obtain endpoint
# + auth details from your Luma enterprise contact before flipping this on.
LUMA_API_KEY=
LUMA_API_BASE=https://api.lumalabs.ai

# ---- Mock checkout ----
# The demo ships with a fully mocked checkout flow (no real Stripe).
# When you're ready, replace src/lib/checkout.ts with a real Stripe integration.
PUBLIC_APP_URL=http://localhost:3000

# ---- Sample scene ----
# Path (relative to /public) of the .ksplat file used by /demo. Run
# `npm run download:sample` once to populate this.
NEXT_PUBLIC_SAMPLE_SPLAT=/splats/room.splat
